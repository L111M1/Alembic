{% set question_types = ["概念解释", "对比分析", "应用题", "正误判断", "简答题", "场景模拟", "案例分析", "推导与证明"] %}
{% set difficulties = ["入门", "进阶", "高级"] %}
{% set sub_topics = knowledge | replace("，", ",") | split(",") if knowledge else [] %}
{% set question_type = random.choice(question_types) %}
{% set difficulty = random.choice(difficulties) %}
{% set sub_topic = random.choice(sub_topics) if sub_topics else "" %}
user: 请为主题 "{{ topic }}" 生成一条 SFT 训练数据。
难度：{{ difficulty }}
提问类型：{{ question_type }}
{% if sub_topic %}子主题：{{ sub_topic }}{% endif %}
{% if knowledge %}参考以下背景知识来确保准确性：
{{ knowledge }}{% endif %}
用纯 JSON 格式输出，只输出 JSON，不要有其他文字：
{
  "instruction": "用户指令",
  "output": "助手回答"
}
